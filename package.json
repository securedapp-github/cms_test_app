{
  "name": "securedapp-cms",
  "version": "1.0.0",
  "description": "Multi-tenant consent management system",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "worker:webhook": "node src/workers/webhook.worker.js",
    "db:create": "node src/scripts/createDatabase.js",
    "db:sync": "node src/scripts/syncDb.js",
    "db:clear": "node src/scripts/clearDb.js",
    "db:seed-catalog": "node src/scripts/seedDataCatalog.js",
    "db:fix-clients-name": "node src/scripts/addClientNameColumn.js",
    "consent:expire": "node src/scripts/expireConsents.js",
    "test:google": "node src/scripts/serve-google-test.js",
    "test:redirect": "node src/scripts/serve-redirect-demo.js",
    "demo:install": "npm install --prefix demo-apps/unified-demo/backend && npm install --prefix demo-apps/unified-demo/frontend",
    "demo:backend": "npm run dev --prefix demo-apps/unified-demo/backend",
    "demo:frontend": "npm run dev --prefix demo-apps/unified-demo/frontend",
    "demo:all": "concurrently -k -n api,ui -c green,cyan \"npm run demo:backend\" \"npm run demo:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.3",
    "sequelize": "^6.35.2",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.19.0"
  }
}

PORT=4200

# Where your CMS backend is running
CMS_BASE_URL=http://localhost:3000

# Tenant JWT (owner/admin) to register webhooks, or just use Swagger to register manually.
CMS_ADMIN_BEARER_TOKEN=replace_me

# Webhook registration target (this ERP simulator)
ERP_WEBHOOK_PUBLIC_URL=http://localhost:4200/webhooks/securedapp

# Secret configured in CMS webhook (used to verify x-webhook-signature). Optional.
ERP_WEBHOOK_SECRET=replace_me_optional


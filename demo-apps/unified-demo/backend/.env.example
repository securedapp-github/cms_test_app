PORT=5050



# --- Optional: local dev only (skip UI connection form) ---

# Production can omit these; the browser sends x-cms-base-url, x-api-key, x-app-id.

# Local: http://localhost:3000 | Production CMS: https://cmsbe.securedapp.io
CMS_BASE_URL=http://localhost:3000

CMS_PUBLIC_API_KEY=replace_me

CMS_APP_ID=replace_me_app_uuid

# --- Server-only (not configurable from the browser) ---

# Public base URL of THIS demo API (for webhook_url in /api/config). If unset, derived from Host / X-Forwarded-*.

PUBLIC_DEMO_API_URL=



# Optional: verify CMS webhook HMAC (CMS calls this server; secret must stay on the server).

ERP_WEBHOOK_SECRET=


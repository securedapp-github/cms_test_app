PORT=5050

# CMS (securedapp_cms)
CMS_BASE_URL=http://localhost:3000

# Public app + API key (consent + redirect flows)
CMS_PUBLIC_API_KEY=replace_me
CMS_APP_ID=replace_me_app_uuid

# Optional: register webhooks from UI (tenant admin JWT)
CMS_ADMIN_BEARER_TOKEN=

# Webhook receiver (this server). Must match URL registered in CMS.
ERP_WEBHOOK_PUBLIC_URL=http://localhost:5050/webhooks/securedapp

# Optional: verify x-webhook-signature
ERP_WEBHOOK_SECRET=
